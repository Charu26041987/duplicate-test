package Stepsdef;

import Variable.Build_Payload;
import io.cucumber.java.en.Given;
import io.cucumber.java.en.Then;
import io.cucumber.java.en.When;
import io.restassured.RestAssured;
import io.restassured.response.Response;
import org.json.JSONObject;


public class Login {

    private Response response;
    private String payload;
    JSONObject bookingPayload;

    @Given("I set the booking")
    public void I_set_the_booking() {

         bookingPayload = new Build_Payload()
                .withBookingid(6)
                .withRoomid(1)
                .withFirstname("James")
                .withLastname("Dean")
                .withDepositPaid(true)
                .withEmail("test@gemail.com")
                .withPhone("07123456789")
                .withCheckin("2025-07-10")
                .withCheckout("2025-07-15")
                .build();


    }

    @When("I send a POST request to create booking")
    public void post_request() {

            response = RestAssured.given()
                    .accept ("*/*")
                    .contentType("application/json")
                    .body(bookingPayload.toString())
                   .when()
                    .post("https://automationintesting.online/booking/");
        }


    @Then("I should receive a {int} status code")
    public void status_code(int statusCode) {
        if (response != null) {
            System.out.println("Status Code: " + response.getStatusCode());
            response.then().assertThat().statusCode(statusCode);
        } else {
            throw new AssertionError("Response is null. Something went wrong with the request.");
        }
    }

